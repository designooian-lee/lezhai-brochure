[PHP]
extension_dir="{{EXT_DIR}}"
extension=curl
extension=fileinfo
extension=mbstring
extension=openssl
extension=pdo_pgsql
extension=pgsql
extension=zip
curl.cainfo="{{CA_FILE}}"
openssl.cafile="{{CA_FILE}}"
date.timezone=Asia/Shanghai
display_errors=On
log_errors=On
error_log="{{ERROR_LOG}}"
session.cookie_httponly=1
session.cookie_samesite=Lax
upload_max_filesize=2G
post_max_size=2100M
max_execution_time=0
memory_limit=256M
